{
    "name": "speakeasy/wp-speakeasy",
    "description": "WordPress automation plugin for REST API enhancements and Application Passwords management",
    "type": "wordpress-plugin",
    "license": "GPL-2.0-or-later",
    "authors": [
        {
            "name": "Speakeasy",
            "email": "dev@speakeasy.com"
        }
    ],
    "require": {
        "php": ">=7.4",
        "yahnis-elsts/plugin-update-checker": "^5.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^9.0",
        "squizlabs/php_codesniffer": "^3.7",
        "wp-coding-standards/wpcs": "^3.0",
        "phpstan/phpstan": "^1.10",
        "yoast/phpunit-polyfills": "^2.0"
    },
    "autoload": {
        "classmap": [
            "includes/",
            "modules/",
            "admin/"
        ]
    },
    "scripts": {
        "test": "phpunit --configuration phpunit.xml.dist",
        "test:coverage": "phpunit --configuration phpunit.xml.dist --coverage-html coverage",
        "phpcs": "phpcs --standard=WordPress --extensions=php --ignore=vendor/ .",
        "phpcbf": "phpcbf --standard=WordPress --extensions=php --ignore=vendor/ .",
        "phpstan": "phpstan analyse --level=8 includes/ modules/ admin/"
    },
    "config": {
        "allow-plugins": {
            "dealerdirect/phpcodesniffer-composer-installer": true
        }
    }
}
